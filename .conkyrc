out_to_console yes
out_to_x no
background no
update_interval 1
total_run_times 0
use_spacer none

TEXT
$if_mpd_playing\
$mpd_smart |\
$endif \
VOL: ${exec amixer get 'Master',0 | egrep -m 1 -o '[0-9]{1,3}%'} | \
CPU: ${cpu cpu1}% | \
TEM: ${execi 6 sensors | grep temp1: | cut -c 16-17}°C | \
MEM: $mem | \
${if_existing /sys/class/power_supply/BAT0}\
BAT: $battery_short | \
$endif\
${time %a %b %d %I:%M%P}
